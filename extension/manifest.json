{
  "manifest_version": 3,
  "name": "Behoerden-Briefkasten (Solid Pod)",
  "version": "0.1.0",
  "description": "Dezentraler Briefkasten: zeigt behoerdliche Dokumente aus deinem Solid Pod und meldet neue Zustellungen.",

  "permissions": [
    "identity",
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],

  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.chromiumapp.org/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Behoerden-Briefkasten"
  },

  "icons": {
    "128": "icon128.png"
  }
}
